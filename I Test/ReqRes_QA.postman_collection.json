{
	"info": {
		"name": "ReqRes API Testing",
		"schema": "https://getpostman.com"
	},
	"item": [
		{
			"name": "Get List Users",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
							"pm.test(\"Response has data array\", function () { pm.expect(pm.response.json().data).to.be.an('array'); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"url": "https://reqres.in/api/users?page=2"
			}
		},
		{
			"name": "Create User",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 201\", function () { pm.response.to.have.status(201); });",
							"var jsonData = pm.response.json();",
							"pm.collectionVariables.set(\"user_id\", jsonData.id);",
							"pm.test(\"Name and Job are correct\", function () {",
							"    pm.expect(jsonData.name).to.eql(\"QA Trainee\");",
							"    pm.expect(jsonData.job).to.eql(\"tester\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"QA Trainee\",\n    \"job\": \"tester\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": "https://reqres.in/api/users"
			}
		},
		{
			"name": "Update User (PUT)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
							"pm.test(\"Has updatedAt field\", function () { pm.expect(pm.response.json()).to.have.property('updatedAt'); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PUT",
				"body": {
					"mode": "raw",
					"raw": "{\n    \"name\": \"QA Trainee Updated\",\n    \"job\": \"senior tester\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": "https://reqres.in/api/users/{{user_id}}"
			}
		},
		{
			"name": "Delete User",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 204\", function () { pm.response.to.have.status(204); });"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "DELETE",
				"url": "https://reqres.in/api/users/{{user_id}}"
			}
		}
	],
	"variable": [
		{ "key": "user_id", "value": "" }
	]
}
